{
  "site_title": "MEOW",
  "site_subtitle": "A Cute Static Blog",
  "author": "小橘猫",
  "description": "一个基于 Meow 主题的纯静态博客",
  "start_date": "2024-04-02T22:16:20",
  "language": "zh-CN",
  "root": "./",
  "theme_color_light": "#FFB347",
  "theme_color_dark": "#88C0ED",
  "default_mode": "light",
  "icon_type": "uc",
  "banner": {
    "title": "「 MEOW 」",
    "subtitle": ["一个简洁的静态博客", "记录技术与生活", "欢迎来到我的小站"],
